DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgis://civiclens:civiclens@postgres:5432/civiclens

# Redis
REDIS_URL=redis://redis:6379/0

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# Anthropic — get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# NYC Open Data (no auth needed, but app token avoids rate limits)
NYC_OPEN_DATA_APP_TOKEN=

# Mapbox (frontend) — get a public token at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token-here
